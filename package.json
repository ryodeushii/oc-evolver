{
  "name": "oc-evolver",
  "$schema": "https://json.schemastore.org/package.json",
  "version": "0.3.1",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.13",
  "exports": {
    ".": "./index.ts",
    "./server": "./index.ts"
  },
  "files": [
    "index.ts",
    "src",
    "eval/runtime-contract.json",
    "README.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test:unit": "bun test",
    "autonomous:run": "bun run scripts/run-autonomous-loop.ts",
    "eval:autonomous-run": "bun run scripts/run-eval.ts autonomous-run",
    "eval:smoke": "bun run scripts/run-eval.ts smoke",
    "eval:all": "bun run scripts/run-eval.ts all"
  },
  "overrides": {
    "uuid": "14.0.0"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.14.31",
    "@opencode-ai/sdk": "^1.14.31",
    "zod": "4.4.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3"
  }
}
